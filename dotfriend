#!/usr/bin/env bash
# dotfriend — Main entry point
# shellcheck shell=bash

set -euo pipefail

# ─────────────────────────────────────────────────────────────
# Resolve library directory
# ─────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

# ─────────────────────────────────────────────────────────────
# Source core libraries
# ─────────────────────────────────────────────────────────────

# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# shellcheck source=lib/bootstrap.sh
source "${LIB_DIR}/bootstrap.sh"

# shellcheck source=lib/api.sh
source "${LIB_DIR}/api.sh"

# ─────────────────────────────────────────────────────────────
# Ensure cache directory exists
# ─────────────────────────────────────────────────────────────

ensure_dir "${DOTFRIEND_CACHE_DIR}"

# ─────────────────────────────────────────────────────────────
# Trap Ctrl+C for clean exit
# ─────────────────────────────────────────────────────────────

_trap_int() {
  printf "\n%sInterrupted.%s\n" "${C_DIM}" "${C_RESET}" >&2
  exit 130
}
trap _trap_int INT

# ─────────────────────────────────────────────────────────────
# Usage
# ─────────────────────────────────────────────────────────────

print_usage() {
  cat <<EOF
${C_BOLD}${C_CYAN}dotfriend${C_RESET} — Generate and maintain your dotfiles repository

${C_BOLD}Usage:${C_RESET}
  dotfriend start          Interactive first-run wizard
  dotfriend generate       Backend-safe repository generation
  dotfriend sync           Incremental sync
  dotfriend agent status --json  Agent artifact backend status
  dotfriend --help         Show this help
  dotfriend --version      Show version

${C_BOLD}Sync flags:${C_RESET}
  dotfriend sync --dry-run      Preview changes without applying
  dotfriend sync --no-commit    Apply changes but don't commit
  dotfriend sync --quick        Non-interactive config sync only

${C_BOLD}Backend-safe generate flags:${C_RESET}
  dotfriend generate --events --target <path> --no-push --force
EOF
}

# ─────────────────────────────────────────────────────────────
# Banner (shown when no subcommand is given)
# ─────────────────────────────────────────────────────────────

print_banner() {
  printf "\n"
  printf "  ${C_BOLD}${C_CYAN}  • ·   ·  ·${C_RESET}\n"
  printf "  ${C_BOLD}${C_CYAN}·  ·  ${C_MAGENTA}◆${C_CYAN}  ·  ·${C_RESET}   dotfriend v%s\n" "${DOTFRIEND_VERSION}"
  printf "  ${C_BOLD}${C_CYAN}  ·  ·   · ·${C_RESET}\n"
  printf "\n"
  printf "  ${C_DIM}Generate and maintain your dotfiles repository.${C_RESET}\n"
  printf "\n"
}

# ─────────────────────────────────────────────────────────────
# Argument parsing
# ─────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  print_banner
  print_usage
  exit 0
fi

ORIGINAL_ARGS=("$@")
DOTFRIEND_API_JSON=false
DOTFRIEND_API_EVENTS=false
DOTFRIEND_NO_BOOTSTRAP=false
DOTFRIEND_APPROVED=false

cmd=""
args=()
for arg in "$@"; do
  case "$arg" in
    --json)
      DOTFRIEND_API_JSON=true
      ;;
    --events)
      DOTFRIEND_API_EVENTS=true
      ;;
    --no-bootstrap)
      DOTFRIEND_NO_BOOTSTRAP=true
      ;;
    --approved)
      DOTFRIEND_APPROVED=true
      ;;
    *)
      if [[ -z "$cmd" ]]; then
        cmd="$arg"
      else
        args+=("$arg")
      fi
      ;;
  esac
done

if [[ -z "$cmd" ]]; then
  cmd="${1:-}"
  shift || true
  args=("$@")
fi

if [[ "${cmd}" == "start" || "${cmd}" == "sync" ]]; then
  if [[ "${DOTFRIEND_NO_BOOTSTRAP}" != "true" && "${DOTFRIEND_RUNTIME_BOOTSTRAPPED:-false}" != "true" ]]; then
    if [[ "${DOTFRIEND_API_JSON}" == "true" || "${DOTFRIEND_API_EVENTS}" == "true" ]]; then
      bootstrap_runtime >&2
    else
      bootstrap_runtime
    fi
    exec env DOTFRIEND_RUNTIME_BOOTSTRAPPED=true "$0" "${ORIGINAL_ARGS[@]}"
  fi
fi

case "${cmd}" in
  start)
    dry_run=false
    for arg in "${args[@]}"; do
      case "$arg" in
        --dry-run) dry_run=true ;;
      esac
    done
    # shellcheck source=lib/wizard.sh
    source "${LIB_DIR}/wizard.sh"
    wizard_start

    # After wizard completes, generate the repository
    # shellcheck source=lib/generate.sh
    source "${LIB_DIR}/generate.sh"
    generate_repo "" "$dry_run"
    ;;

  generate)
    if [[ "${DOTFRIEND_API_EVENTS}" != "true" ]]; then
      api_fail "generate" "events_required" "Use dotfriend generate --events --target <path>."
      exit 2
    fi

    target_dir=""
    no_push=false
    force=false
    while [[ ${#args[@]} -gt 0 ]]; do
      case "${args[0]}" in
        --target)
          if [[ ${#args[@]} -lt 2 || -z "${args[1]}" ]]; then
            api_fail "generate" "target_required" "Use --target <path>."
            exit 2
          fi
          target_dir="${args[1]}"
          args=("${args[@]:2}")
          ;;
        --no-push)
          no_push=true
          args=("${args[@]:1}")
          ;;
        --force)
          force=true
          args=("${args[@]:1}")
          ;;
        *)
          api_fail "generate" "unknown_generate_flag" "Unknown generate flag: ${args[0]}"
          exit 2
          ;;
      esac
    done

    if [[ -z "$target_dir" ]]; then
      api_fail "generate" "target_required" "Use --target <path>."
      exit 2
    fi

    # shellcheck source=lib/generate.sh
    source "${LIB_DIR}/generate.sh"
    export DOTFRIEND_GENERATE_EVENTS=true
    export DOTFRIEND_GENERATE_NO_PUSH="$no_push"
    export DOTFRIEND_GENERATE_FORCE="$force"
    GEN_EVENTS=true
    GEN_NO_PUSH="$no_push"
    GEN_FORCE="$force"

    exec 3>&1
    GEN_EVENT_FD=3
    _generate_emit_event "job_started" "$(jq -cn --arg job "generate" --arg target "$target_dir" '{job:$job,target:$target}')"
    if generate_repo "$target_dir" false >&2; then
      _generate_emit_event "job_finished" "$(jq -cn --arg job "generate" --arg status "ok" '{job:$job,status:$status}')"
      exec 3>&-
      exit 0
    fi
    _generate_emit_event "error" '{"code":"generation_failed","message":"Generation failed."}'
    _generate_emit_event "job_finished" "$(jq -cn --arg job "generate" --arg status "failed" '{job:$job,status:$status}')"
    exec 3>&-
    exit 1
    ;;

  sync)
    # shellcheck source=lib/sync.sh
    source "${LIB_DIR}/sync.sh"
    cmd_sync "${args[@]}"
    ;;

  preflight)
    if [[ "${DOTFRIEND_API_JSON}" != "true" ]]; then
      api_fail "preflight" "json_required" "Use dotfriend preflight --json."
      exit 2
    fi
    # shellcheck source=lib/preflight.sh
    source "${LIB_DIR}/preflight.sh"
    preflight_run_json
    ;;

  discover)
    if [[ "${DOTFRIEND_API_JSON}" != "true" && "${DOTFRIEND_API_EVENTS}" != "true" ]]; then
      api_fail "discover" "json_or_events_required" "Use dotfriend discover --json or dotfriend discover --events."
      exit 2
    fi
    # shellcheck source=lib/discovery.sh
    source "${LIB_DIR}/discovery.sh"
    discover_cached=false
    for arg in "${args[@]}"; do
      case "$arg" in
        --cached) discover_cached=true ;;
      esac
    done
    if [[ "${discover_cached}" == "true" && "${DOTFRIEND_API_EVENTS}" == "true" ]]; then
      api_fail "discover" "cached_events_unsupported" "Use dotfriend discover --json --cached."
      exit 2
    fi
    if [[ "${discover_cached}" == "true" ]]; then
      api_print_envelope "ok" "discover" "$(discovery_cache_data_json)"
      exit 0
    fi
    if [[ "${DOTFRIEND_API_EVENTS}" == "true" ]]; then
      api_event "job_started" '{"job":"discover"}'
      api_event "step_started" '{"step":"discovery","label":"Scanning system"}'
      if run_discovery >&2; then
        api_event "step_finished" '{"step":"discovery","status":"ok"}'
        api_event "job_finished" '{"job":"discover","status":"ok"}'
      else
        api_event "error" '{"code":"discovery_failed","message":"Discovery failed."}'
        api_event "job_finished" '{"job":"discover","status":"failed"}'
        exit 1
      fi
    else
      if run_discovery >&2; then
        api_print_envelope "ok" "discover" "$(discovery_cache_data_json)"
      else
        api_fail "discover" "discovery_failed" "Discovery failed."
        exit 1
      fi
    fi
    ;;

  status)
    if [[ "${DOTFRIEND_API_JSON}" != "true" ]]; then
      api_fail "status" "json_required" "Use dotfriend status --json."
      exit 2
    fi
    # shellcheck source=lib/status.sh
    source "${LIB_DIR}/status.sh"
    status_print_json "status"
    ;;

  plan)
    if [[ "${DOTFRIEND_API_JSON}" != "true" ]]; then
      api_fail "plan" "json_required" "Use dotfriend plan --json."
      exit 2
    fi
    # shellcheck source=lib/status.sh
    source "${LIB_DIR}/status.sh"
    status_print_json "plan"
    ;;

  agent)
    # shellcheck source=lib/agent-artifacts.sh
    source "${LIB_DIR}/agent-artifacts.sh"
    agent_cmd "${args[@]}"
    ;;

  --help|-h)
    print_usage
    exit 0
    ;;

  --version|-v)
    printf "dotfriend %s\n" "${DOTFRIEND_VERSION}"
    exit 0
    ;;

  *)
    log_error "Unknown command: ${cmd}"
    printf "\n" >&2
    print_usage >&2
    exit 1
    ;;
esac
